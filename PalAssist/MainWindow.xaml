<Window x:Class="PalAssist.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PalAssist"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        WindowState="Normal"
        ResizeMode="NoResize">

    <Canvas x:Name="RootCanvas">

        <!-- ═══════════════════════════════════════════
             CROSSHAIR (center of overlay; never hit-tests)
             ═══════════════════════════════════════════ -->
        <Canvas x:Name="CrosshairCanvas" IsHitTestVisible="False"
                Visibility="Collapsed" Width="48" Height="48"/>

        <!-- ═══════════════════════════════════════════
             CONSOLIDATED HUD PANEL (top-right default)
             ═══════════════════════════════════════════ -->
        <Border x:Name="HudPanel" Canvas.Top="12"
                CornerRadius="8" Padding="12,6"
                Visibility="Collapsed"
                MouseLeftButtonDown="HudPanel_MouseLeftButtonDown"
                MouseMove="HudPanel_MouseMove"
                MouseLeftButtonUp="HudPanel_MouseLeftButtonUp">
            <Border.Background>
                <SolidColorBrush Color="#1A1A2E" Opacity="0.88"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00D2FF" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <StackPanel x:Name="HudStack">
                <!-- Rows added/removed dynamically from code-behind -->
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════
             MAIN MENU CARD (tabbed)
             ═══════════════════════════════════════════ -->
        <Border x:Name="MenuPanel" Width="560"
                CornerRadius="16" Padding="0"
                Visibility="Collapsed"
                MouseLeftButtonDown="MenuPanel_MouseLeftButtonDown"
                MouseMove="MenuPanel_MouseMove"
                MouseLeftButtonUp="MenuPanel_MouseLeftButtonUp">
            <Border.Background>
                <SolidColorBrush Color="#16213E" Opacity="0.94"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="32" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F3460" Offset="0"/>
                    <GradientStop Color="#00D2FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>1</Thickness>
            </Border.BorderThickness>

            <StackPanel>

                <!-- ── Title Bar ── -->
                <Border CornerRadius="16,16,0,0" Padding="20,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0F3460" Offset="0"/>
                            <GradientStop Color="#1A1A2E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Title + subtitle -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PalAssist"
                                       FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentCyanBrush}"/>
                            <TextBlock x:Name="HeaderVersionText"
                                       Text="External Input Assist"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Game detection indicator -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,14,0">
                            <Ellipse x:Name="GameDot" Width="8" Height="8"
                                     Fill="{DynamicResource AccentRedBrush}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="GameStatusText" Text="Palworld not found"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Close button -->
                        <Button Grid.Column="2" x:Name="CloseBtn"
                                Content="×" Width="28" Height="28"
                                FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                Click="CloseBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBd" CornerRadius="8"
                                            Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBd" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#FF1744" Opacity="0.25"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="#FF1744"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── Body: vertical tabs + content ── -->
                <Grid MinHeight="480">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="118"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left rail -->
                    <Border Grid.Column="0" Background="#0F3460" Opacity="0.35"
                            CornerRadius="0" Padding="0,8,0,8">
                        <StackPanel>
                            <Button x:Name="TabAssists" Content="Assists"
                                    Style="{StaticResource VerticalTabBtnStyle}"
                                    Click="TabAssists_Click"/>
                            <Button x:Name="TabBeta" Content="Beta"
                                    Style="{StaticResource VerticalTabBtnStyle}"
                                    Visibility="Collapsed"
                                    Click="TabBeta_Click"/>
                            <Button x:Name="TabSettings" Content="Settings"
                                    Style="{StaticResource VerticalTabBtnStyle}"
                                    Click="TabSettings_Click"/>
                            <Button x:Name="TabChangelog" Content="Changes"
                                    Style="{StaticResource VerticalTabBtnStyle}"
                                    ToolTip="What's Changed — full version history"
                                    Click="TabChangelog_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Right content -->
                    <Grid Grid.Column="1">
                <!-- ════════════════════════════════════════
                     TAB CONTENT: Assists
                     ════════════════════════════════════════ -->
                <StackPanel x:Name="PanelAssists">

                    <!-- ── Work Assist ── -->
                    <Border Margin="14,10,14,6" Padding="14,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.7"/>
                        </Border.Background>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="WorkAssistDot" Width="9" Height="9"
                                                 Fill="{DynamicResource AccentRedBrush}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Work Assist"
                                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Style="{StaticResource HelpHintStyle}">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="300">
                                                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12">
                                                        <Run FontWeight="SemiBold" Text="What: "/><Run Text="Holds F for work / interact.&#x0a;"/>
                                                        <Run FontWeight="SemiBold" Text="When: "/><Run Text="Crafting stations, farms, and long hold-to-work actions so you don’t hold F yourself."/>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="WorkAssistSubtitle"
                                               Text="Holds F  ·  Hotkey: F1"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="17,3,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="WorkAssistToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="WorkAssistToggle_Changed"
                                              Unchecked="WorkAssistToggle_Changed"/>
                            </Grid>

                            <!-- Show HUD Indicator checkbox -->
                            <CheckBox x:Name="WorkAssistShowHudCheck" Content="Show HUD Indicator"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI" FontSize="11"
                                      Margin="17,6,0,0"
                                      Checked="WorkAssistShowHudCheck_Changed"
                                      Unchecked="WorkAssistShowHudCheck_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Focus Lock (stable) ── -->
                    <Border Margin="14,2,14,6" Padding="14,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.7"/>
                        </Border.Background>
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="FocusLockDot" Width="9" Height="9"
                                                 Fill="{DynamicResource AccentRedBrush}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Focus Lock"
                                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Style="{StaticResource HelpHintStyle}">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="300">
                                                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12">
                                                        <Run FontWeight="SemiBold" Text="What: "/><Run Text="Releases held assist keys when Palworld is not focused.&#x0a;"/>
                                                        <Run FontWeight="SemiBold" Text="When: "/><Run Text="Alt-tabbing, opening the menu, or AFK with another app in front so keys don’t stick."/>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Release keys when game unfocused"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="17,3,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="FocusLockToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="FocusLockToggle_Changed"
                                              Unchecked="FocusLockToggle_Changed"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="17,0,0,0">
                                <Ellipse x:Name="FocusLockStatusDot" Width="8" Height="8" Margin="0,0,6,0"
                                         Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="FocusLockStatusText" Text="Focus lock off"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Sprint Assist (disabled in v1.1; kept in tree for re-enable) ── -->
                    <Border x:Name="SprintAssistCard" Margin="14,2,14,10" Padding="14,12" CornerRadius="10"
                            Visibility="Collapsed">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.7"/>
                        </Border.Background>
                        <StackPanel>
                            <!-- Header row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="SprintDot" Width="9" Height="9"
                                                 Fill="{DynamicResource AccentRedBrush}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Sprint Assist"
                                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="SprintSubtitle"
                                               Text="Auto forward + sprint cycles  ·  Hotkey: F2"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="17,3,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="SprintToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="SprintToggle_Changed"
                                              Unchecked="SprintToggle_Changed"/>
                            </Grid>

                            <!-- Status line -->
                            <TextBlock x:Name="SprintStatusText" Text="Idle"
                                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="17,8,0,4"/>

                            <!-- Sprint Duration slider -->
                            <Grid Margin="17,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sprint:" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="SprintDurSlider" Grid.Column="1"
                                        Style="{StaticResource ModernSlider}"
                                        Minimum="3" Maximum="20" Value="8"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ValueChanged="SprintDurSlider_Changed"/>
                                <TextBlock x:Name="SprintDurLabel" Grid.Column="2"
                                           Text="8.0s" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource AccentCyanBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Recovery Duration slider -->
                            <Grid Margin="17,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recovery:" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="RecoveryDurSlider" Grid.Column="1"
                                        Style="{StaticResource ModernSlider}"
                                        Minimum="2" Maximum="15" Value="4"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ValueChanged="RecoveryDurSlider_Changed"/>
                                <TextBlock x:Name="RecoveryDurLabel" Grid.Column="2"
                                           Text="4.0s" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource AccentCyanBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Pause when dodging checkbox -->
                            <CheckBox x:Name="PauseDodgeCheck" Content="Pause when dodging (Ctrl)"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI" FontSize="11"
                                      Margin="17,6,0,0"
                                      Checked="PauseDodgeCheck_Changed"
                                      Unchecked="PauseDodgeCheck_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Crosshair ── -->
                    <Border Margin="14,2,14,10" Padding="14,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.7"/>
                        </Border.Background>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Crosshair"
                                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Style="{StaticResource HelpHintStyle}">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="300">
                                                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12">
                                                        <Run FontWeight="SemiBold" Text="What: "/><Run Text="Draws a simple reticle over the game.&#x0a;"/>
                                                        <Run FontWeight="SemiBold" Text="When: "/><Run Text="You want an extra aim marker without changing game settings."/>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Fixed center reticle"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="CrosshairToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="CrosshairToggle_Changed"
                                              Unchecked="CrosshairToggle_Changed"/>
                            </Grid>

                            <StackPanel x:Name="CrosshairOptionsPanel" Margin="0,10,0,0" IsEnabled="False">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Style" FontFamily="Segoe UI" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CrosshairStyleCombo" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}" Width="120"
                                              SelectionChanged="CrosshairOption_Changed">
                                        <ComboBoxItem Content="Dot" IsSelected="True"/>
                                        <ComboBoxItem Content="Plus"/>
                                        <ComboBoxItem Content="X"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Size" FontFamily="Segoe UI" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CrosshairSizeCombo" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}" Width="120"
                                              SelectionChanged="CrosshairOption_Changed">
                                        <ComboBoxItem Content="Small"/>
                                        <ComboBoxItem Content="Medium" IsSelected="True"/>
                                        <ComboBoxItem Content="Large"/>
                                    </ComboBox>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Color" FontFamily="Segoe UI" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CrosshairColorCombo" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}" Width="120"
                                              SelectionChanged="CrosshairOption_Changed">
                                        <ComboBoxItem Content="White" IsSelected="True"/>
                                        <ComboBoxItem Content="Cyan"/>
                                        <ComboBoxItem Content="Red"/>
                                        <ComboBoxItem Content="Green"/>
                                        <ComboBoxItem Content="Yellow"/>
                                        <ComboBoxItem Content="Magenta"/>
                                        <ComboBoxItem Content="Orange"/>
                                        <ComboBoxItem Content="Blue"/>
                                        <ComboBoxItem Content="Pink"/>
                                        <ComboBoxItem Content="Black"/>
                                        <ComboBoxItem Content="Lime"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Stop all assists -->
                    <Border Margin="14,0,14,10" Padding="12,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.55"/>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Emergency stop"
                                               FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border Style="{StaticResource HelpHintStyle}">
                                        <Border.ToolTip>
                                            <ToolTip MaxWidth="300">
                                                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12">
                                                    <Run FontWeight="SemiBold" Text="What: "/><Run Text="Turns off all assists and releases held keys immediately.&#x0a;"/>
                                                    <Run FontWeight="SemiBold" Text="When: "/><Run Text="Keys feel stuck or you need a hard stop without closing PalAssist."/>
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Disable assists + release keys"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Stop all"
                                    Style="{StaticResource RebindBtnStyle}"
                                    Click="StopAllAssistsBtn_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ════════════════════════════════════════
                     TAB CONTENT: Beta (experimental)
                     ════════════════════════════════════════ -->
                <StackPanel x:Name="PanelBeta" Visibility="Collapsed">

                    <!-- Banner -->
                    <Border Margin="14,10,14,6" Padding="12,8" CornerRadius="8">
                        <Border.Background>
                            <SolidColorBrush Color="#3D2A1A" Opacity="0.7"/>
                        </Border.Background>
                        <TextBlock Text="⚠ Experimental — stable Assists are unchanged. Test here before promote."
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#FFB74D" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Smart Work Assist -->
                    <Border Margin="14,2,14,10" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Smart Work Assist" FontFamily="Segoe UI" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Style="{StaticResource HelpHintStyle}">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="300">
                                                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12">
                                                        <Run FontWeight="SemiBold" Text="What: "/><Run Text="When Work Assist turns on: tap F once, wait 1s, then hold F.&#x0a;"/>
                                                        <Run FontWeight="SemiBold" Text="When: "/><Run Text="An item is already sitting on a workstation — pick it up first, then work."/>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Tap F → wait 1s → hold (pickup first)"
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,2,8,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="BetaSmartWorkAssistToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Top"
                                              Checked="BetaSmartWorkAssistToggle_Changed"
                                              Unchecked="BetaSmartWorkAssistToggle_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ════════════════════════════════════════
                     TAB CONTENT: Settings
                     ════════════════════════════════════════ -->
                <ScrollViewer x:Name="PanelSettings" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" MaxHeight="520"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ── Hotkeys Section ── -->
                    <Border Margin="14,10,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="Hotkeys" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <!-- Menu Toggle -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Menu Toggle" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RebindMenuBtn" Grid.Column="1"
                                        Content="Insert" Style="{StaticResource RebindBtnStyle}"
                                        Click="RebindMenuBtn_Click"/>
                            </Grid>
                            <!-- Work Assist Toggle -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Work Assist Toggle" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RebindWorkAssistBtn" Grid.Column="1"
                                        Content="F1" Style="{StaticResource RebindBtnStyle}"
                                        Click="RebindWorkAssistBtn_Click"/>
                            </Grid>
                            <!-- Sprint Toggle (disabled in v1.1) -->
                            <Grid x:Name="SprintHotkeyRow" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sprint Toggle" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RebindSprintBtn" Grid.Column="1"
                                        Content="F2" Style="{StaticResource RebindBtnStyle}"
                                        Click="RebindSprintBtn_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── HUD / Indicator Settings ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="HUD / Indicators" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <!-- Position preset -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Position" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="HudPresetCombo" Grid.Column="1"
                                          Style="{StaticResource DarkCombo}" Width="120"
                                          SelectionChanged="HudPresetCombo_Changed">
                                    <ComboBoxItem Content="Top-Left"/>
                                    <ComboBoxItem Content="Top-Center"/>
                                    <ComboBoxItem Content="Top-Right" IsSelected="True"/>
                                    <ComboBoxItem Content="Bottom-Left"/>
                                    <ComboBoxItem Content="Bottom-Center"/>
                                    <ComboBoxItem Content="Bottom-Right"/>
                                </ComboBox>
                            </Grid>
                            <!-- Draggable toggle -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Make Indicator Draggable" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ToggleButton x:Name="HudDraggableToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              Checked="HudDraggableToggle_Changed"
                                              Unchecked="HudDraggableToggle_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Appearance ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="Appearance" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Opacity" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="UiOpacitySlider" Grid.Column="1"
                                        Style="{StaticResource ModernSlider}"
                                        Minimum="0.5" Maximum="1.0" Value="0.94"
                                        TickFrequency="0.02" IsSnapToTickEnabled="True"
                                        ValueChanged="UiOpacitySlider_Changed"/>
                                <TextBlock x:Name="UiOpacityLabel" Grid.Column="2"
                                           Text="94%" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource AccentCyanBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="UI Scale" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="UiScaleCombo" Grid.Column="1"
                                          Style="{StaticResource DarkCombo}" Width="100"
                                          SelectionChanged="UiScaleCombo_Changed">
                                    <ComboBoxItem Content="85%" Tag="0.85"/>
                                    <ComboBoxItem Content="100%" Tag="1.0" IsSelected="True"/>
                                    <ComboBoxItem Content="115%" Tag="1.15"/>
                                    <ComboBoxItem Content="130%" Tag="1.3"/>
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Color Theme" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="UiThemeCombo" Grid.Column="1"
                                          Style="{StaticResource DarkCombo}" Width="100"
                                          SelectionChanged="UiThemeCombo_Changed">
                                    <ComboBoxItem Content="Cyan" IsSelected="True"/>
                                    <ComboBoxItem Content="Purple"/>
                                    <ComboBoxItem Content="Green"/>
                                    <ComboBoxItem Content="Amber"/>
                                    <ComboBoxItem Content="Red"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Sound ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="Sound" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Enable Sounds" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ToggleButton x:Name="SoundEnabledToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              Checked="SoundSettings_Changed"
                                              Unchecked="SoundSettings_Changed"/>
                            </Grid>
                            <CheckBox x:Name="SoundOnToggleCheck" Content="Play on assist toggle"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"
                                      Checked="SoundSettings_Changed" Unchecked="SoundSettings_Changed"/>
                            <CheckBox x:Name="SoundOnFocusCheck" Content="Play on focus lock suspend/resume"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"
                                      Checked="SoundSettings_Changed" Unchecked="SoundSettings_Changed"/>
                            <CheckBox x:Name="SoundOnUpdateCheck" Content="Play when update is available"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI" FontSize="11"
                                      Checked="SoundSettings_Changed" Unchecked="SoundSettings_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- ── System Tray ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="System Tray" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Show Tray Icon" FontFamily="Segoe UI" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="Right-click for Show Menu / Exit"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="TrayEnabledToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="TraySettings_Changed"
                                              Unchecked="TraySettings_Changed"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Minimize to Tray" FontFamily="Segoe UI" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="Taskbar close hides the app instead of exiting"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="MinimizeToTrayToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="TraySettings_Changed"
                                              Unchecked="TraySettings_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Safety ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="Safety" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="AFK safety" FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Border Style="{StaticResource HelpHintStyle}">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="300">
                                                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12">
                                                        <Run FontWeight="SemiBold" Text="What: "/><Run Text="Turns off all assists if Palworld stays closed for 10 minutes.&#x0a;"/>
                                                        <Run FontWeight="SemiBold" Text="When: "/><Run Text="Leave PalAssist running overnight or after closing the game so keys don’t stay held."/>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Auto-stop assists if game closed 10+ min"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="AfkSafetyToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="AfkSafetyToggle_Changed"
                                              Unchecked="AfkSafetyToggle_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Config Manager ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Config" FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Border Style="{StaticResource HelpHintStyle}">
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="300">
                                            <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                                                       Text="Backup or restore config.json, open the settings folder, or reset everything to defaults."/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="ConfigStatusText" Text=""
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{DynamicResource AccentCyanBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Button Content="Open folder" Style="{StaticResource RebindBtnStyle}"
                                        Margin="0,0,8,6" Click="ConfigOpenFolderBtn_Click"/>
                                <Button Content="Export…" Style="{StaticResource RebindBtnStyle}"
                                        Margin="0,0,8,6" Click="ConfigExportBtn_Click"/>
                                <Button Content="Import…" Style="{StaticResource RebindBtnStyle}"
                                        Margin="0,0,8,6" Click="ConfigImportBtn_Click"/>
                                <Button Content="Reset defaults" Style="{StaticResource RebindBtnStyle}"
                                        Margin="0,0,0,6" Click="ConfigResetBtn_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Experimental / Beta ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="Experimental" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Enable Beta" FontFamily="Segoe UI" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Border Style="{StaticResource HelpHintStyle}">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="300">
                                                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12">
                                                        <Run FontWeight="SemiBold" Text="What: "/><Run Text="Unlocks the Beta tab.&#x0a;"/>
                                                        <Run FontWeight="SemiBold" Text="When: "/><Run Text="You want experimental options like Smart Work Assist."/>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="?" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Unlocks Smart Work Assist on Beta"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="BetaEnabledToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="BetaEnabledToggle_Changed"
                                              Unchecked="BetaEnabledToggle_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Save Settings Button ── -->
                    <Button x:Name="SaveSettingsBtn" Margin="14,2,14,6" Height="34"
                            Content="Save Settings" Style="{StaticResource RebindBtnStyle}"
                            Background="#0F3460" Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderThickness="0" Click="SaveSettingsBtn_Click"
                            ToolTip="Write current settings to config.json">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#00D2FF"/>
                                        <Setter Property="Foreground" Value="#16213E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ── About Section ── -->
                    <Border Margin="14,2,14,10" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.4"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="About" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="VersionText" Text="PalAssist" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="External Input Assist • No memory reading"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,4"/>
                            <TextBlock x:Name="UpdateStatusText" Text=""
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{DynamicResource AccentCyanBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="UpdateBtn" Content="Check for Updates"
                                        Style="{StaticResource RebindBtnStyle}"
                                        Click="UpdateBtn_Click" Margin="0,0,8,0"/>
                                <Button x:Name="InstallUpdateBtn" Content="Install &amp; Restart"
                                        Style="{StaticResource RebindBtnStyle}"
                                        Click="InstallUpdateBtn_Click"
                                        Visibility="Collapsed" IsEnabled="false" Margin="0,0,8,0"/>
                                <Button x:Name="ChangelogBtn" Content="What's Changed"
                                        Style="{StaticResource RebindBtnStyle}"
                                        Click="ChangelogBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>

                <!-- ════════════════════════════════════════
                     TAB CONTENT: What's Changed
                     ════════════════════════════════════════ -->
                <ScrollViewer x:Name="PanelChangelog" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" MaxHeight="520"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Margin="14,10,14,6" Padding="12,8" CornerRadius="8">
                            <Border.Background>
                                <SolidColorBrush Color="#1A1A2E" Opacity="0.5"/>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="What's Changed"
                                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="All PalAssist versions — newest first. Scroll for older releases."
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <StackPanel x:Name="ChangelogStack" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
                    </Grid><!-- end right content -->
                </Grid><!-- end body grid -->

                <!-- ── Footer ── -->
                <Border CornerRadius="0,0,16,16" Padding="18,8">
                    <Border.Background>
                        <SolidColorBrush Color="#0F3460" Opacity="0.4"/>
                    </Border.Background>
                    <TextBlock FontFamily="Segoe UI" FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center">
                        <Run x:Name="FooterMenuKey" Text="Insert" FontWeight="Bold"
                             Foreground="{DynamicResource AccentCyanBrush}"/>
                        <Run Text=" menu  ·  "/>
                        <Run x:Name="FooterWorkAssistKey" Text="F1" FontWeight="Bold"
                             Foreground="{DynamicResource AccentCyanBrush}"/>
                        <Run Text=" work"/>
                        <Run x:Name="FooterSprintSep" Text=""/>
                        <Run x:Name="FooterSprintKey" Text="" FontWeight="Bold"
                             Foreground="{DynamicResource AccentCyanBrush}"/>
                        <Run x:Name="FooterSprintLabel" Text=""/>
                    </TextBlock>
                </Border>

            </StackPanel>
        </Border>
    </Canvas>
</Window>
