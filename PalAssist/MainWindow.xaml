<Window x:Class="PalAssist.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PalAssist"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        WindowState="Normal"
        ResizeMode="NoResize">

    <Canvas x:Name="RootCanvas">

        <!-- ═══════════════════════════════════════════
             CONSOLIDATED HUD PANEL (top-right default)
             ═══════════════════════════════════════════ -->
        <Border x:Name="HudPanel" Canvas.Top="12"
                CornerRadius="8" Padding="12,6"
                Visibility="Collapsed"
                MouseLeftButtonDown="HudPanel_MouseLeftButtonDown"
                MouseMove="HudPanel_MouseMove"
                MouseLeftButtonUp="HudPanel_MouseLeftButtonUp">
            <Border.Background>
                <SolidColorBrush Color="#1A1A2E" Opacity="0.88"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00D2FF" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <StackPanel x:Name="HudStack">
                <!-- Rows added/removed dynamically from code-behind -->
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════
             MAIN MENU CARD (tabbed)
             ═══════════════════════════════════════════ -->
        <Border x:Name="MenuPanel" Width="460"
                CornerRadius="16" Padding="0"
                Visibility="Collapsed"
                MouseLeftButtonDown="MenuPanel_MouseLeftButtonDown"
                MouseMove="MenuPanel_MouseMove"
                MouseLeftButtonUp="MenuPanel_MouseLeftButtonUp">
            <Border.Background>
                <SolidColorBrush Color="#16213E" Opacity="0.94"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="32" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F3460" Offset="0"/>
                    <GradientStop Color="#00D2FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>1</Thickness>
            </Border.BorderThickness>

            <StackPanel>

                <!-- ── Title Bar ── -->
                <Border CornerRadius="16,16,0,0" Padding="20,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0F3460" Offset="0"/>
                            <GradientStop Color="#1A1A2E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Title + subtitle -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PalAssist"
                                       FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource AccentCyanBrush}"/>
                            <TextBlock x:Name="HeaderVersionText"
                                       Text="External Input Assist"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Game detection indicator -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,14,0">
                            <Ellipse x:Name="GameDot" Width="8" Height="8"
                                     Fill="{StaticResource AccentRedBrush}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="GameStatusText" Text="Game not found"
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Close button -->
                        <Button Grid.Column="2" x:Name="CloseBtn"
                                Content="×" Width="28" Height="28"
                                FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                Click="CloseBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBd" CornerRadius="8"
                                            Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBd" Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#FF1744" Opacity="0.25"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="#FF1744"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── Tabs Row ── -->
                <Border Padding="4,0">
                    <Border.Background>
                        <SolidColorBrush Color="#0F3460" Opacity="0.3"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="TabAssists" Content="Assists"
                                Style="{StaticResource TabBtnStyle}"
                                Click="TabAssists_Click"/>
                        <Button x:Name="TabAI" Content="AI Assists"
                                Style="{StaticResource TabBtnStyle}"
                                Click="TabAI_Click"/>
                        <Button x:Name="TabSettings" Content="Settings"
                                Style="{StaticResource TabBtnStyle}"
                                Click="TabSettings_Click"/>
                    </StackPanel>
                </Border>

                <!-- ── Divider ── -->
                <Rectangle Height="1" Margin="16,0">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#00D2FF" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- ════════════════════════════════════════
                     TAB CONTENT: Assists
                     ════════════════════════════════════════ -->
                <StackPanel x:Name="PanelAssists">

                    <!-- ── Work Assist ── -->
                    <Border Margin="14,10,14,6" Padding="14,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.7"/>
                        </Border.Background>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="WorkAssistDot" Width="9" Height="9"
                                                 Fill="{StaticResource AccentRedBrush}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Work Assist"
                                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="WorkAssistSubtitle"
                                               Text="Continuously holds the F key  ·  Hotkey: F1"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="17,3,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="WorkAssistToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="WorkAssistToggle_Changed"
                                              Unchecked="WorkAssistToggle_Changed"/>
                            </Grid>

                            <!-- Show HUD Indicator checkbox -->
                            <CheckBox x:Name="WorkAssistShowHudCheck" Content="Show HUD Indicator"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI" FontSize="11"
                                      Margin="17,6,0,0"
                                      Checked="WorkAssistShowHudCheck_Changed"
                                      Unchecked="WorkAssistShowHudCheck_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Sprint Assist ── -->
                    <Border Margin="14,2,14,10" Padding="14,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.7"/>
                        </Border.Background>
                        <StackPanel>
                            <!-- Header row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="SprintDot" Width="9" Height="9"
                                                 Fill="{StaticResource AccentRedBrush}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Sprint Assist"
                                                   FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="SprintSubtitle"
                                               Text="Auto forward + sprint cycles  ·  Hotkey: F2"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="17,3,0,0"/>
                                </StackPanel>
                                <ToggleButton x:Name="SprintToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Checked="SprintToggle_Changed"
                                              Unchecked="SprintToggle_Changed"/>
                            </Grid>

                            <!-- Status line -->
                            <TextBlock x:Name="SprintStatusText" Text="Idle"
                                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="17,8,0,4"/>

                            <!-- Sprint Duration slider -->
                            <Grid Margin="17,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sprint:" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="SprintDurSlider" Grid.Column="1"
                                        Style="{StaticResource ModernSlider}"
                                        Minimum="3" Maximum="20" Value="8"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ValueChanged="SprintDurSlider_Changed"/>
                                <TextBlock x:Name="SprintDurLabel" Grid.Column="2"
                                           Text="8.0s" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{StaticResource AccentCyanBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Recovery Duration slider -->
                            <Grid Margin="17,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recovery:" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="RecoveryDurSlider" Grid.Column="1"
                                        Style="{StaticResource ModernSlider}"
                                        Minimum="2" Maximum="15" Value="4"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                                        ValueChanged="RecoveryDurSlider_Changed"/>
                                <TextBlock x:Name="RecoveryDurLabel" Grid.Column="2"
                                           Text="4.0s" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{StaticResource AccentCyanBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Pause when dodging checkbox -->
                            <CheckBox x:Name="PauseDodgeCheck" Content="Pause when dodging (Ctrl)"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI" FontSize="11"
                                      Margin="17,6,0,0"
                                      Checked="PauseDodgeCheck_Changed"
                                      Unchecked="PauseDodgeCheck_Changed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ════════════════════════════════════════
                     TAB CONTENT: AI Assists (placeholder)
                     ════════════════════════════════════════ -->
                <StackPanel x:Name="PanelAI" Visibility="Collapsed">
                    <Border Margin="14,20" Padding="30" CornerRadius="10" HorizontalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.5"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🤖" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="AI Assists"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Coming in a future update"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ════════════════════════════════════════
                     TAB CONTENT: Settings
                     ════════════════════════════════════════ -->
                <StackPanel x:Name="PanelSettings" Visibility="Collapsed">

                    <!-- ── Hotkeys Section ── -->
                    <Border Margin="14,10,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="Hotkeys" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <!-- Menu Toggle -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Menu Toggle" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RebindMenuBtn" Grid.Column="1"
                                        Content="Insert" Style="{StaticResource RebindBtnStyle}"
                                        Click="RebindMenuBtn_Click"/>
                            </Grid>
                            <!-- Work Assist Toggle -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Work Assist Toggle" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RebindWorkAssistBtn" Grid.Column="1"
                                        Content="F1" Style="{StaticResource RebindBtnStyle}"
                                        Click="RebindWorkAssistBtn_Click"/>
                            </Grid>
                            <!-- Sprint Toggle -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sprint Toggle" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RebindSprintBtn" Grid.Column="1"
                                        Content="F2" Style="{StaticResource RebindBtnStyle}"
                                        Click="RebindSprintBtn_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── HUD / Indicator Settings ── -->
                    <Border Margin="14,2,14,6" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="HUD / Indicators" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <!-- Position preset -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Position" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="HudPresetCombo" Grid.Column="1"
                                          Style="{StaticResource DarkCombo}" Width="120"
                                          SelectionChanged="HudPresetCombo_Changed">
                                    <ComboBoxItem Content="Top-Left"/>
                                    <ComboBoxItem Content="Top-Center"/>
                                    <ComboBoxItem Content="Top-Right" IsSelected="True"/>
                                    <ComboBoxItem Content="Bottom-Left"/>
                                    <ComboBoxItem Content="Bottom-Center"/>
                                    <ComboBoxItem Content="Bottom-Right"/>
                                </ComboBox>
                            </Grid>
                            <!-- Draggable toggle -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Make Indicator Draggable" FontFamily="Segoe UI" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ToggleButton x:Name="HudDraggableToggle" Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              Checked="HudDraggableToggle_Changed"
                                              Unchecked="HudDraggableToggle_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Save Settings Button ── -->
                    <Button x:Name="SaveSettingsBtn" Margin="14,2,14,6" Height="34"
                            Content="Save Settings" Style="{StaticResource RebindBtnStyle}"
                            Background="#0F3460" Foreground="{StaticResource TextPrimaryBrush}"
                            BorderThickness="0" Click="SaveSettingsBtn_Click"
                            ToolTip="Write current settings to config.json">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#00D2FF"/>
                                        <Setter Property="Foreground" Value="#16213E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ── About Section ── -->
                    <Border Margin="14,2,14,10" Padding="14,10" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="#1A1A2E" Opacity="0.4"/>
                        </Border.Background>
                        <StackPanel>
                            <TextBlock Text="About" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="VersionText" Text="PalAssist" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="External Input Assist • No memory reading"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,4"/>
                            <TextBlock x:Name="UpdateStatusText" Text=""
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="{StaticResource AccentCyanBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="UpdateBtn" Content="Check for Updates"
                                        Style="{StaticResource RebindBtnStyle}"
                                        Click="UpdateBtn_Click" Margin="0,0,8,0"/>
                                <Button x:Name="InstallUpdateBtn" Content="Install &amp; Restart"
                                        Style="{StaticResource RebindBtnStyle}"
                                        Click="InstallUpdateBtn_Click"
                                        Visibility="Collapsed" IsEnabled="false"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Footer ── -->
                <Border CornerRadius="0,0,16,16" Padding="18,8">
                    <Border.Background>
                        <SolidColorBrush Color="#0F3460" Opacity="0.4"/>
                    </Border.Background>
                    <TextBlock FontFamily="Segoe UI" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Center">
                        <Run x:Name="FooterMenuKey" Text="Insert" FontWeight="Bold"
                             Foreground="{StaticResource AccentCyanBrush}"/>
                        <Run Text=" menu  ·  "/>
                        <Run x:Name="FooterWorkAssistKey" Text="F1" FontWeight="Bold"
                             Foreground="{StaticResource AccentCyanBrush}"/>
                        <Run Text=" work  ·  "/>
                        <Run x:Name="FooterSprintKey" Text="F2" FontWeight="Bold"
                             Foreground="{StaticResource AccentCyanBrush}"/>
                        <Run Text=" sprint"/>
                    </TextBlock>
                </Border>

            </StackPanel>
        </Border>
    </Canvas>
</Window>
